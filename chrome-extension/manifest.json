{
  "manifest_version": 3,
  "name": "Finalyst Deal Sourcing",
  "version": "1.0.0",
  "description": "Capture target company details and import them directly into Finalyst as a new Deal.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}
